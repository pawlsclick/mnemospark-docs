+    },
+    body: JSON.stringify(request),
+  });
+
+  const responseBody = await response.text();
+  if (!response.ok) {
+    throw new Error(responseBody || `Upload confirm proxy failed with status ${response.status}`);
+  }
+
+  let payload: unknown;
+  try {
+    payload = JSON.parse(responseBody);
